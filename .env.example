# TCAI v6 — Environment Configuration
# Copy this file to home/.env and fill in your values.

# === Required ===
# DeepSeek API Key (get one at https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-key-here

# === Optional ===
# DeepSeek API base URL (default: https://api.deepseek.com/v1)
# DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# Model name (default: deepseek-chat)
# TCAI_MODEL=deepseek-chat

# Knowledge base path (default: ../TCAI_Knowledge relative to project root)
# TCAI_KNOWLEDGE_PATH=

# GitHub token for push_to_github.py (optional)
# GITHUB_TOKEN=
